<Window x:Class="SystemTools.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:SystemTools.Desktop.ViewModels"
        Title="System-tools Diagnostics"
        Width="1280" Height="800" MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header -->
            <RowDefinition Height="Auto" />  <!-- toolbar -->
            <RowDefinition Height="*" />     <!-- content -->
            <RowDefinition Height="Auto" />  <!-- status -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel>
                <TextBlock Text="SYSTEM-TOOLS"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Diagnostics"
                           FontSize="22" FontWeight="SemiBold" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource BgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Run Diagnostics"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnRunClick"
                        IsEnabled="{Binding CanRun}" />
                <CheckBox Content="Sanitize PII"
                          Margin="20,0,0,0" VerticalAlignment="Center"
                          IsChecked="{Binding SanitizeEnabled}" />
                <CheckBox Content="Include crash dumps"
                          Margin="16,0,0,0" VerticalAlignment="Center"
                          IsChecked="{Binding IncludeMiniDumpsEnabled}" />
                <TextBlock Text="Network capture:"
                           Margin="20,0,6,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <TextBox Width="60" VerticalAlignment="Center" VerticalContentAlignment="Center"
                         Text="{Binding CaptureNetSeconds, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="seconds (0 = off)"
                           Margin="6,0,0,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
        </Border>

        <!-- Content: history + report -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- History sidebar -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="16,12,16,8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="History" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding History.Count, StringFormat=' ({0})'}"
                                       Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Border>
                    <ListBox ItemsSource="{Binding History}"
                             SelectedItem="{Binding SelectedRun}"
                             ItemContainerStyle="{StaticResource HistoryItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding DisplayDate}" FontWeight="SemiBold" />
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                        <Border Background="#DCFCE7" CornerRadius="999" Padding="6,1" Margin="2,0">
                                            <TextBlock Text="{Binding OkCount}" Foreground="{StaticResource OkBrush}"
                                                       FontSize="10" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Background="#FEF3C7" CornerRadius="999" Padding="6,1" Margin="2,0">
                                            <TextBlock Text="{Binding WarnCount}" Foreground="{StaticResource WarnBrush}"
                                                       FontSize="10" FontWeight="SemiBold" />
                                        </Border>
                                        <Border Background="#FEE2E2" CornerRadius="999" Padding="6,1" Margin="2,0">
                                            <TextBlock Text="{Binding FailCount}" Foreground="{StaticResource FailBrush}"
                                                       FontSize="10" FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                                               Text="{Binding ProjectAndHost}"
                                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                                               Margin="0,2,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Report viewer -->
            <Grid Grid.Column="2">
                <wv2:WebView2 x:Name="ReportView"
                              Source="{Binding SelectedReportUri}"
                              Visibility="{Binding HasSelectedReport, Converter={StaticResource BoolToVis}}" />

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasSelectedReport, Converter={StaticResource InvertedBoolToVis}}">
                    <TextBlock Text="No report selected"
                               FontSize="16" Foreground="{StaticResource MutedBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Run diagnostics or pick an entry from the history list."
                               Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <vm:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis" />
    </Window.Resources>
</Window>
