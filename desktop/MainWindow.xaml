<Window x:Class="SystemTools.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SystemTools.Desktop.ViewModels"
        xmlns:v="clr-namespace:SystemTools.Desktop.Views"
        Title="System-tools Diagnostics"
        Width="1280" Height="800" MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <vm:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVis" />
        <vm:EnumEqualsConverter x:Key="EnumEquals" />

        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="White" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header -->
            <RowDefinition Height="*" />     <!-- nav + content -->
            <RowDefinition Height="Auto" />  <!-- status -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,14">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="SYSTEM-TOOLS"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Diagnostics" FontSize="22" FontWeight="SemiBold" Margin="0,2,0,0" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Settings.CurrentVersion, StringFormat='v{0}'}"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Bottom" Margin="0,0,0,4" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar nav -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel>
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="Run" Click="OnNavRun"
                                 IsChecked="{Binding SelectedTab, Mode=OneWay, Converter={StaticResource EnumEquals}, ConverterParameter=Run}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="Diff" Click="OnNavDiff"
                                 IsChecked="{Binding SelectedTab, Mode=OneWay, Converter={StaticResource EnumEquals}, ConverterParameter=Diff}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="Trends" Click="OnNavTrends"
                                 IsChecked="{Binding SelectedTab, Mode=OneWay, Converter={StaticResource EnumEquals}, ConverterParameter=Trends}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="Plugins" Click="OnNavPlugins"
                                 IsChecked="{Binding SelectedTab, Mode=OneWay, Converter={StaticResource EnumEquals}, ConverterParameter=Plugins}" />
                    <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                 Content="Settings" Click="OnNavSettings"
                                 IsChecked="{Binding SelectedTab, Mode=OneWay, Converter={StaticResource EnumEquals}, ConverterParameter=Settings}" />
                </StackPanel>
            </Border>

            <!-- Content swap based on selected tab -->
            <Grid Grid.Column="1">
                <v:RunView      Visibility="{Binding IsRunTab,      Converter={StaticResource BoolToVis}}" />
                <v:DiffView     Visibility="{Binding IsDiffTab,     Converter={StaticResource BoolToVis}}" />
                <v:TrendsView   Visibility="{Binding IsTrendsTab,   Converter={StaticResource BoolToVis}}" />
                <v:PluginsView  Visibility="{Binding IsPluginsTab,  Converter={StaticResource BoolToVis}}" />
                <v:SettingsView Visibility="{Binding IsSettingsTab, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,8">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</Window>
