<UserControl x:Class="SystemTools.Desktop.Views.DiffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Compare two diagnostic runs"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

        <Grid Grid.Row="1" Margin="0,0,0,12" DataContext="{Binding Diff}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Old run" Foreground="{StaticResource MutedBrush}" FontSize="11"
                           FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding Runs}" SelectedItem="{Binding OldRun}"
                          DisplayMemberPath="DisplayDate" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                <TextBlock Text="New run" Foreground="{StaticResource MutedBrush}" FontSize="11"
                           FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding Runs}" SelectedItem="{Binding NewRun}"
                          DisplayMemberPath="DisplayDate" Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="2" Content="Compare"
                    Style="{StaticResource PrimaryButton}"
                    VerticalAlignment="Bottom" Margin="8,0,0,0"
                    Click="OnCompareClick"
                    IsEnabled="{Binding CanCompare}" />
        </Grid>

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Background="{StaticResource PanelBrush}" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding Diff.Output, Mode=OneWay}"
                         FontFamily="Consolas, ui-monospace, monospace"
                         FontSize="12"
                         Padding="14" BorderThickness="0"
                         Background="Transparent"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
