<UserControl x:Class="SystemTools.Desktop.Views.PluginsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20" DataContext="{Binding Plugins}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Plugins"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Text="{Binding PluginsDir, StringFormat='Drop .ps1 files into {0} or use Import below.'}"
                   Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,0,0,12"
                   TextWrapping="Wrap" />

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Background="{StaticResource PanelBrush}">
            <DataGrid ItemsSource="{Binding Plugins}"
                      SelectedItem="{Binding SelectedPlugin}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True" HeadersVisibility="Column"
                      BorderThickness="0" GridLinesVisibility="Horizontal"
                      Background="Transparent" RowBackground="Transparent"
                      AlternatingRowBackground="#F3F4F6">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Plugin"        Binding="{Binding Name}"          Width="*"   />
                    <DataGridCheckBoxColumn Header="Enabled"   Binding="{Binding Enabled}"       Width="80"  />
                    <DataGridTextColumn Header="Size"          Binding="{Binding DisplaySize}"   Width="80"  />
                    <DataGridTextColumn Header="Modified"      Binding="{Binding LastWriteTime, StringFormat=yyyy-MM-dd}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Import .ps1..." Click="OnImportClick" Padding="12,6" Margin="0,0,8,0" />
            <Button Content="Enable"  Click="OnEnableClick"  Padding="12,6" Margin="0,0,8,0"
                    IsEnabled="{Binding CanEnable}" />
            <Button Content="Disable" Click="OnDisableClick" Padding="12,6" Margin="0,0,8,0"
                    IsEnabled="{Binding CanDisable}" />
            <Button Content="Delete"  Click="OnDeleteClick"  Padding="12,6" Margin="0,0,8,0"
                    IsEnabled="{Binding HasSelection}" />
            <Button Content="Open folder" Click="OnOpenClick" Padding="12,6" Margin="0,0,8,0" />
            <Button Content="Reload"      Click="OnReloadClick" Padding="12,6" />
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}"
                       Margin="16,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
