# Copy this file to .env and fill in credentials for the platforms you use.
# Any platform with missing credentials will be reported as "not configured"
# and skipped at post time — you don't need to fill all three.

# --- Flask ---
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# --- Twitter / X (API v2, OAuth 1.0a user context) ---
# Create an app at https://developer.x.com, generate user access tokens with
# read+write permission. Free tier allows ~17 posts/24h per user.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- Bluesky (AT Protocol) ---
# Use your handle (e.g. yourname.bsky.social) and an APP PASSWORD generated at
# https://bsky.app/settings/app-passwords — NOT your main account password.
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# --- Facebook (Graph API, page posting) ---
# Create an app at https://developers.facebook.com, get a long-lived Page
# access token with pages_manage_posts + pages_read_engagement scopes, and
# the numeric ID of the page you want to post to.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
